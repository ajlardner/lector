{
  "name": "lector",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm --filter @lector/shared build && pnpm -r --parallel --filter=./apps/* dev",
    "dev:web": "pnpm --filter @lector/shared build && pnpm --filter ./apps/web dev",
    "dev:api": "pnpm --filter @lector/shared build && pnpm --filter ./apps/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter ./apps/web db:generate",
    "db:push": "pnpm --filter ./apps/web db:push"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "eslint": "^9.12.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0"
  }
}
